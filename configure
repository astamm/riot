#! /bin/sh

RSCRIPT_BIN=${R_HOME}/bin/Rscript

cd src

#### CMAKE CONFIGURATION ####
. ./scripts/cmake_config.sh

sh ./scripts/vtk_download.sh ${RSCRIPT_BIN}
. ./scripts/r_config.sh
${CMAKE_BIN} \
  -D BUILD_SHARED_LIBS=OFF \
  -D CMAKE_BUILD_TYPE=Release \
  -D CMAKE_AR=${AR} \
  -D CMAKE_RANLIB=${RANLIB} \
  -D VTK_ENABLE_LOGGING=OFF \
  -D VTK_ENABLE_REMOTE_MODULES=OFF \
  -D VTK_ENABLE_WRAPPING=OFF \
  -D VTK_GROUP_ENABLE_StandAlone=WANT \
  -D VTK_INSTALL_SDK=ON \
  -D VTK_PYTHON_FULL_THREADSAFE=OFF \
  -D VTK_USE_COCOA=OFF \
  -D VTK_VERSIONED_INSTALL=OFF \
  -S vtk-src \
  -B vtk-build
sh ./scripts/vtk_install.sh "${CMAKE_BIN}"
sh ./scripts/vtk_cleanup.sh
